{
  "module": "Delta",
  "method": "transformPosition",
  "tests": [
    {
      "name": "insert before position",
      "delta": [{ "insert": "A" }],
      "index": 2,
      "expected": 3
    },
    {
      "name": "insert after position",
      "delta": [{ "retain": 2 }, { "insert": "A" }],
      "index": 1,
      "expected": 1
    },
    {
      "name": "insert at position (priority)",
      "delta": [{ "retain": 2 }, { "insert": "A" }],
      "index": 2,
      "priority": true,
      "expected": 2
    },
    {
      "name": "insert at position (no priority)",
      "delta": [{ "retain": 2 }, { "insert": "A" }],
      "index": 2,
      "priority": false,
      "expected": 3
    },
    {
      "name": "delete before position",
      "delta": [{ "delete": 2 }],
      "index": 4,
      "expected": 2
    },
    {
      "name": "delete after position",
      "delta": [{ "retain": 4 }, { "delete": 2 }],
      "index": 2,
      "expected": 2
    },
    {
      "name": "delete across position",
      "delta": [{ "retain": 1 }, { "delete": 4 }],
      "index": 2,
      "expected": 1
    },
    {
      "name": "insert and delete before position",
      "delta": [{ "retain": 2 }, { "insert": "A" }, { "delete": 2 }],
      "index": 4,
      "expected": 3
    },
    {
      "name": "insert before and delete across position",
      "delta": [{ "retain": 2 }, { "insert": "A" }, { "delete": 4 }],
      "index": 4,
      "expected": 3
    },
    {
      "name": "delete before and delete across position",
      "delta": [{ "delete": 1 }, { "retain": 1 }, { "delete": 4 }],
      "index": 4,
      "expected": 1
    }
  ]
}
