{
  "module": "Delta",
  "method": "helpers",
  "tests": {
    "concat": [
      {
        "name": "empty delta",
        "a": [{ "insert": "Test" }],
        "b": [],
        "expected": [{ "insert": "Test" }]
      },
      {
        "name": "unmergeable",
        "a": [{ "insert": "Test" }],
        "b": [{ "insert": "!", "attributes": { "bold": true } }],
        "expected": [{ "insert": "Test" }, { "insert": "!", "attributes": { "bold": true } }]
      },
      {
        "name": "mergeable",
        "a": [{ "insert": "Test", "attributes": { "bold": true } }],
        "b": [{ "insert": "!", "attributes": { "bold": true } }, { "insert": "\n" }],
        "expected": [{ "insert": "Test!", "attributes": { "bold": true } }, { "insert": "\n" }]
      }
    ],
    "chop": [
      {
        "name": "retain",
        "input": [{ "insert": "Test" }, { "retain": 4 }],
        "expected": [{ "insert": "Test" }]
      },
      {
        "name": "insert",
        "input": [{ "insert": "Test" }],
        "expected": [{ "insert": "Test" }]
      },
      {
        "name": "formatted retain",
        "input": [{ "insert": "Test" }, { "retain": 4, "attributes": { "bold": true } }],
        "expected": [{ "insert": "Test" }, { "retain": 4, "attributes": { "bold": true } }]
      }
    ],
    "changeLength": [
      {
        "name": "mixed",
        "input": [
          { "insert": "AB", "attributes": { "bold": true } },
          { "retain": 2, "attributes": { "bold": null } },
          { "delete": 1 }
        ],
        "expected": 1
      }
    ],
    "length": [
      {
        "name": "document",
        "input": [{ "insert": "AB", "attributes": { "bold": true } }, { "insert": { "embed": 1 } }],
        "expected": 3
      },
      {
        "name": "mixed",
        "input": [
          { "insert": "AB", "attributes": { "bold": true } },
          { "insert": { "embed": 1 } },
          { "retain": 2, "attributes": { "bold": null } },
          { "delete": 1 }
        ],
        "expected": 6
      },
      {
        "name": "emoji",
        "input": [{ "insert": "😀" }],
        "expected": 2
      },
      {
        "name": "emoji mixed",
        "input": [{ "insert": "a😀b" }, { "retain": 1 }],
        "expected": 5
      }
    ],
    "slice": [
      {
        "name": "start",
        "input": [{ "retain": 2 }, { "insert": "A" }],
        "start": 2,
        "expected": [{ "insert": "A" }]
      },
      {
        "name": "start and end chop",
        "input": [{ "insert": "0123456789" }],
        "start": 2,
        "end": 7,
        "expected": [{ "insert": "23456" }]
      },
      {
        "name": "start and end multiple chop",
        "input": [{ "insert": "0123", "attributes": { "bold": true } }, { "insert": "4567" }],
        "start": 3,
        "end": 5,
        "expected": [{ "insert": "3", "attributes": { "bold": true } }, { "insert": "4" }]
      },
      {
        "name": "start and end",
        "input": [{ "retain": 2 }, { "insert": "A", "attributes": { "bold": true } }, { "insert": "B" }],
        "start": 2,
        "end": 3,
        "expected": [{ "insert": "A", "attributes": { "bold": true } }]
      },
      {
        "name": "no params",
        "input": [{ "retain": 2 }, { "insert": "A", "attributes": { "bold": true } }, { "insert": "B" }],
        "expected": [{ "retain": 2 }, { "insert": "A", "attributes": { "bold": true } }, { "insert": "B" }]
      },
      {
        "name": "split ops",
        "input": [{ "insert": "AB", "attributes": { "bold": true } }, { "insert": "C" }],
        "start": 1,
        "end": 2,
        "expected": [{ "insert": "B", "attributes": { "bold": true } }]
      },
      {
        "name": "split ops multiple times",
        "input": [{ "insert": "ABC", "attributes": { "bold": true } }, { "insert": "D" }],
        "start": 1,
        "end": 2,
        "expected": [{ "insert": "B", "attributes": { "bold": true } }]
      },
      {
        "name": "slice around emoji",
        "input": [{ "insert": "a😀b" }],
        "start": 1,
        "end": 3,
        "expected": [{ "insert": "😀" }]
      }
    ]
  }
}
